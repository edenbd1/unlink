# Unlink tenant API key (server-side only, never sent to the browser or the Ledger)
UNLINK_API_KEY=
UNLINK_ENVIRONMENT=base-sepolia

# EVM wallet that pays gas for the one-time Permit2 approval / deploys (testnet)
FUNDING_PRIVATE_KEY=

# Demo ERC-4626 vault (USDC) on Base Sepolia, prefilled in the device front
DEMO_VAULT=0xaf1ac7cd3f19e008129d1b7cd8da5daa09143482

# Reliable Base Sepolia RPC
BASE_SEPOLIA_RPC=https://base-sepolia-rpc.publicnode.com

# OpenPGP web app (webapp/) only:
PORT=8787
LEDGER_OPENPGP_RECIPIENT=
FIDO_ORIGIN=http://localhost:3000
FIDO_RP_ID=localhost

# Yield co-pilot: set to use Claude (otherwise a deterministic fallback is used)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
DEMO_VAULT_B=0x9cabfc6a6f8711767f3d89ff6e08be8fa22dc453

# Yield co-pilot via Mistral (preferred). Or ANTHROPIC_API_KEY. Else a deterministic fallback.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest
