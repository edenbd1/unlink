# Unlink API key — https://dashboard.unlink.xyz (Base Sepolia project)
UNLINK_API_KEY=your_unlink_api_key_here
UNLINK_ENVIRONMENT=base-sepolia
# Fingerprint/id of the OpenPGP key held by your Ledger (My Ledger → OpenPGP app)
LEDGER_OPENPGP_RECIPIENT=your_ledger_openpgp_key_id
# Optional: a testnet EVM wallet (with USDC) used to top up the private account.
# FUNDING_PRIVATE_KEY=0x...
PORT=8787
